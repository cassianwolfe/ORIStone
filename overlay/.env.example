# ORI API (required)
ORI_API_BASE=https://glm.thynaptic.com/v1
ORI_API_KEY=your_ori_api_key_here

# Blizzard OAuth (required for collection + deck builder)
BLIZZ_CLIENT_ID=your_blizzard_client_id
BLIZZ_CLIENT_SECRET=your_blizzard_client_secret
BLIZZ_REGION=us
# Redirect URI to register in your Blizzard dev console:
#   http://localhost:9898/oauth/callback
